generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Lead {
  id           Int       @id @default(autoincrement())
  source       String
  contactName  String
  phone        String
  serviceType  String
  expectedTime DateTime?
  address      String?
  remark       String?
  status       String    @default("new")
  ownerId      Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("leads")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  level     String   @default("normal")
  source    String?
  tags      String?
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model Employee {
  id                 Int       @id @default(autoincrement())
  name               String
  phone              String
  roleType           String
  skillTags          String?
  certificateNo      String?
  healthCertExpireAt DateTime?
  status             String    @default("available")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("employees")
}

model Order {
  id                 Int      @id @default(autoincrement())
  orderNo            String   @unique
  customerId         Int
  leadId             Int?
  serviceItemName    String
  serviceType        String
  serviceDate        DateTime
  amount             Decimal  @db.Decimal(10, 2)
  status             String   @default("pending_confirm")
  paymentStatus      String   @default("unpaid")
  assignedEmployeeId Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("orders")
}

model ContentPage {
  id        Int            @id @default(autoincrement())
  pageKey   String         @unique
  title     String
  lead      String
  status    String         @default("published")
  blocks    ContentBlock[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("content_pages")
}

model ContentBlock {
  id         Int         @id @default(autoincrement())
  pageId     Int
  page       ContentPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  blockKey   String
  blockType  String
  contentJson String     @db.LongText
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([pageId, sortOrder])
  @@map("content_blocks")
}

model ServiceStandard {
  id        Int      @id @default(autoincrement())
  category  String
  title     String
  content   String   @db.Text
  sortOrder Int      @default(0)
  status    String   @default("published")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_standards")
}
